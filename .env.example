# ============================================
# UrduCoder — Environment Variables Template
# Copy this to .env.local and fill in your values
# ============================================

# Public site URL (used for sitemap, OG images, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://urducoder.vercel.app

# Web3Forms access key (https://web3forms.com)
# Used by the Contact form to send emails directly to your inbox
NEXT_PUBLIC_WEB3FORMS_KEY=

# ============================================
# ADS — Master Switch
# Set to "true" to enable ALL ads. Set to "false" or unset to disable.
# Dev mode shows placeholders regardless of this flag.
# ============================================
NEXT_PUBLIC_ENABLE_ADS=false

# ============================================
# Google AdSense (https://adsense.google.com)
# ============================================
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
NEXT_PUBLIC_ADSENSE_AUTO_ADS=true
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MIDDLE=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=

# ============================================
# Adsterra (https://publishers.adsterra.com)
# Copy the FULL script URL from each ad unit's "GET CODE" modal.
# ============================================

# Popunder — full <script src="..."> URL
NEXT_PUBLIC_ADSTERRA_POPUNDER_URL=

# Social Bar — full <script src="..."> URL
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR_URL=

# Native Banner — full <script src="..."> URL + the container hex ID
# (the hex string after "container-" in the <div id="container-..."> tag)
NEXT_PUBLIC_ADSTERRA_NATIVE_URL=
NEXT_PUBLIC_ADSTERRA_NATIVE_CONTAINER=

# Banner (728x90) — only the hex `key` value from the atOptions object
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
