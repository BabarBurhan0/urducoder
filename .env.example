# ============================================
# UrduCoder — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ============================================

# Public site URL (used for sitemap, OG images, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://urducoder.vercel.app

# Web3Forms access key (https://web3forms.com)
# Used by the Contact form to send emails directly to your inbox
NEXT_PUBLIC_WEB3FORMS_KEY=

# ============================================
# ADS — Master Switch
# Set to "true" to enable ALL ads (only works in production)
# ============================================
NEXT_PUBLIC_ENABLE_ADS=false

# ============================================
# Google AdSense
# Get these after AdSense approval: https://adsense.google.com
# ============================================

# Your AdSense Publisher ID (e.g., ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=

# Auto Ads (Google places ads automatically): "true" or "false"
NEXT_PUBLIC_ADSENSE_AUTO_ADS=true

# Manual Ad Slot IDs (create these in AdSense dashboard)
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MIDDLE=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=

# ============================================
# Adsterra
# Get these after Adsterra approval: https://adsterra.com
# ============================================

# Banner ad key (for in-article banners)
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=

# Social Bar key (notification-style ad at top/bottom)
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR_KEY=

# Native Banner key (content-style ad)
NEXT_PUBLIC_ADSTERRA_NATIVE_KEY=

# Popunder key (opens new tab on click — use carefully)
NEXT_PUBLIC_ADSTERRA_POPUNDER_KEY=
